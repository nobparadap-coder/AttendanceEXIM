<service>
	<id>attendanceeximserver.exe</id>
	<name>AttendanceEXIM Server</name>
	<description>Attendance System + Auto-Backup รันเป็น Windows Service</description>
	<executable>C:\Program Files\nodejs\node.exe</executable>
	<argument>--harmony</argument>
	<argument>--max_old_space_size=4096</argument>
	<argument>C:\Users\Pattanan\node_modules\node-windows\lib\wrapper.js</argument>
	<argument>--file</argument>
	<argument>C:\Users\Pattanan\AttendanceEXIM\server.js</argument>
	<argument>--scriptoptions=</argument>
	<argument>--log</argument>
	<argument>AttendanceEXIM Server wrapper</argument>
	<argument>--grow</argument>
	<argument>0.25</argument>
	<argument>--wait</argument>
	<argument>1</argument>
	<argument>--maxrestarts</argument>
	<argument>3</argument>
	<argument>--abortonerror</argument>
	<argument>n</argument>
	<argument>--stopparentfirst</argument>
	<argument>undefined</argument>
	<logmode>rotate</logmode>
	<stoptimeout>30sec</stoptimeout>
	<serviceaccount>
		<domain>LAPTOP-TRLAGAHQ</domain>
		<user>LocalSystem</user>
		<password></password>
	</serviceaccount>
	<workingdirectory>C:\Users\Pattanan\AttendanceEXIM</workingdirectory>
</service>